{
  "name": "strong-mock",
  "version": "9.2.2",
  "description": "Type safe mocking library for TypeScript",
  "keywords": [
    "tdd",
    "test",
    "mock",
    "stub",
    "fake",
    "test double",
    "expectation",
    "interface",
    "type",
    "typescript",
    "ts",
    "diff",
    "matcher"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiGhTTraX/strong-mock.git"
  },
  "author": "Andrei Picus",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "docs": "doctoc --title '**Table of Contents**' README.md",
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json --attw --publint",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version",
    "lint": "eslint --quiet .",
    "test": "vitest --coverage",
    "test-build": "node tests/build.cjs && node tests/build.mjs",
    "posttest": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "jest-diff": "~30.4.0",
    "jest-matcher-utils": "~30.4.0",
    "lodash": "~4.18.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.0",
    "@nighttrax/eslint-config-ts": "~13.2.0",
    "@types/lodash": "~4.17.0",
    "@types/node": "~24.13.0",
    "@vitest/coverage-v8": "~4.1.0",
    "doctoc": "~2.5.0",
    "eslint": "~10.6.0",
    "prettier": "~3.9.0",
    "publint": "~0.3.18",
    "sm-old": "npm:strong-mock@8.0.1",
    "standard-version": "~9.5.0",
    "strip-ansi": "~7.2.0",
    "tsdown": "~0.22.0",
    "typescript": "~7.0.0",
    "vitest": "~4.1.0"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
