{
  "name": "strong-mock",
  "version": "9.2.2",
  "description": "Type safe mocking library for TypeScript",
  "keywords": [
    "tdd",
    "test",
    "mock",
    "stub",
    "fake",
    "test double",
    "expectation",
    "interface",
    "type",
    "typescript",
    "ts",
    "diff",
    "matcher"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiGhTTraX/strong-mock.git"
  },
  "author": "Andrei Picus",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "docs": "doctoc --title '**Table of Contents**' README.md",
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json --attw --publint",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version",
    "lint": "eslint --quiet .",
    "test": "vitest --coverage",
    "test-build": "node tests/build.cjs && node tests/build.mjs",
    "posttest": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "jest-diff": "~30.4.0",
    "jest-matcher-utils": "~30.4.0",
    "lodash": "~4.18.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.0",
    "@nighttrax/eslint-config-ts": "~13.1.1",
    "@types/lodash": "~4.17.0",
    "@types/node": "~24.13.0",
    "@vitest/coverage-v8": "~4.1.0",
    "doctoc": "~2.5.0",
    "eslint": "~10.6.0",
    "prettier": "~3.8.0",
    "publint": "~0.3.18",
    "sm-old": "npm:strong-mock@8.0.1",
    "standard-version": "~9.5.0",
    "strip-ansi": "~7.2.0",
    "tsdown": "~0.22.0",
    "typescript": "~6.0.0",
    "vitest": "~4.1.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
